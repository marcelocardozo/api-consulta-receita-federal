# Chaves Gemini separadas por vírgula (pelo menos uma obrigatória)
GEMINI_API_KEYS=key1,key2,key3

# Ou chave única
# GEMINI_API_KEY=sua_chave_aqui

# Configurações da aplicação (opcional - valores padrão mostrados)
# APP_HOST=0.0.0.0
# APP_PORT=8000
# BROWSER_HEADLESS=true
# BROWSER_TIMEOUT=30000
# CAPTCHA_EXECUTION_TIMEOUT=90.0
# CAPTCHA_RESPONSE_TIMEOUT=20.0
# LOG_LEVEL=INFO
# IP_LOCK_TTL_SECONDS=300
